{
  "name": "featherfinder-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-react-leaflet.js",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "update-wingspan-birds": "tsx scripts/update-wingspan-birds.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:a11y": "start-server-and-test 'npm run build && npm run preview' http://localhost:4173 pa11y-ci",
    "test:a11y:dev": "start-server-and-test dev http://localhost:5173 'pa11y-ci -c .pa11yci.dev.json'"
  },
  "dependencies": {
    "embla-carousel-react": "^8.6.0",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-onboarding": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "pa11y-ci": "^4.1.0",
    "pa11y-ci-reporter-html": "^8.0.1",
    "playwright": "^1.58.2",
    "start-server-and-test": "^2.1.5",
    "storybook": "^10.2.15",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "vite": "^6.3.5",
    "vitest": "^2.1.6"
  }
}
